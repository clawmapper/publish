# Server
PORT=3000
BASE_URL=https://your-service.railway.app
DATABASE_PATH=./publish.db

# Security — generate strong random values for production
SESSION_SECRET=replace-with-a-long-random-string
API_MASTER_KEY=replace-with-a-long-random-string

# Resend (required for email_domain / email_list auth modes)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com
